# ============================================================
# E-Commerce App — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to version control.
# ============================================================

# ------------------------------------------------------------
# Database
# ------------------------------------------------------------
DB_ROOT_PASSWORD=rootpassword123
DB_PASSWORD=ecommercepassword123

# ------------------------------------------------------------
# JWT Authentication
# ------------------------------------------------------------
# Must be at least 32 characters (256-bit). Generate with:
#   openssl rand -base64 32
JWT_SECRET=your_super_secret_jwt_key_minimum_32_characters_long
JWT_EXPIRATION_MS=900000
JWT_REFRESH_EXPIRATION_MS=604800000

# ------------------------------------------------------------
# Frontend
# ------------------------------------------------------------
# Backend API base URL (without trailing slash)
# For local Docker Compose dev:
REACT_APP_API_URL=http://localhost:8080/api/v1

# ------------------------------------------------------------
# GitHub Container Registry (CI/CD)
# ------------------------------------------------------------
# Personal Access Token with write:packages scope
# Create at: https://github.com/settings/tokens
GHCR_TOKEN=ghp_your_github_personal_access_token

# ------------------------------------------------------------
# Kubernetes (CI/CD)
# ------------------------------------------------------------
# Base64-encoded kubeconfig file
# Generate with: cat ~/.kube/config | base64 | tr -d '\n'
KUBECONFIG=your_base64_encoded_kubeconfig_here

# ------------------------------------------------------------
# Slack Notifications (Optional)
# ------------------------------------------------------------
# Incoming webhook URL for deployment notifications
# Leave empty to disable Slack notifications
SLACK_WEBHOOK_URL=
