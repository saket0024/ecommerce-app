{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Frontend (React dev server)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["start"],
      "cwd": "./frontend",
      "port": 3000
    },
    {
      "name": "Backend (Spring Boot)",
      "runtimeExecutable": "mvn",
      "runtimeArgs": ["spring-boot:run"],
      "cwd": "./backend",
      "port": 8080
    },
    {
      "name": "Full Stack (Docker Compose)",
      "runtimeExecutable": "docker",
      "runtimeArgs": ["compose", "up"],
      "port": 3000
    }
  ]
}
